# BREAST CANCER ANN CLASSIFIER (Python/Keras Version)
# End-to-end Kaggle Notebook Code with All Fixes

# --- Suppress TensorFlow GPU warnings ---
import os
os.environ['TF_CPP_MIN_LOG_LEVEL'] = '3'

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from sklearn.model_selection import StratifiedKFold
from sklearn.metrics import confusion_matrix, roc_curve, auc
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.decomposition import PCA
import tensorflow as tf
from tensorflow.keras.layers import Dense, Dropout
from tensorflow.keras.utils import to_categorical
from tensorflow.keras.callbacks import EarlyStopping
from mpl_toolkits.mplot3d import Axes3D

# Disable GPU if CUDA errors are noisy (CPU fallback)
tf.config.set_visible_devices([], 'GPU')

# SECTION 1 — DATA LOADING
df = pd.read_csv("/kaggle/input/breast-cancer-wisconsin-data/data.csv")
df = df.drop(columns=['id','Unnamed: 32'])

# Detect target column automatically
target_col = [c for c in df.columns if df[c].dtype == 'object'][0]
y_raw = df[target_col]
X = df.drop(columns=[target_col]).values

# Encode labels
le = LabelEncoder()
y = le.fit_transform(y_raw)
y_cat = to_categorical(y)

# SECTION 2 — PREPROCESSING
scaler = StandardScaler()
X = scaler.fit_transform(X)

# SECTION 3 — ANN ARCHITECTURE
def build_model(input_dim):
    inputs = tf.keras.Input(shape=(input_dim,))
    x = Dense(100, activation='relu', name="hidden_layer")(inputs)
    x = Dropout(0.3)(x)
    outputs = Dense(2, activation='softmax')(x)
    model = tf.keras.Model(inputs=inputs, outputs=outputs)
    model.compile(optimizer='adam', loss='categorical_crossentropy', metrics=['accuracy'])
    return model

# SECTION 4 — 3-FOLD CROSS-VALIDATION (lighter)
kf = StratifiedKFold(n_splits=3, shuffle=True, random_state=42)
metrics = []
early_stop = EarlyStopping(monitor='loss', patience=5, restore_best_weights=True)

for fold, (train_idx, test_idx) in enumerate(kf.split(X, y)):
    X_train, X_test = X[train_idx], X[test_idx]
    y_train, y_test = y_cat[train_idx], y_cat[test_idx]

    model = build_model(X.shape[1])
    model.fit(X_train, y_train, epochs=50, batch_size=32, verbose=1, callbacks=[early_stop])

    y_pred_prob = model.predict(X_test)
    y_pred = np.argmax(y_pred_prob, axis=1)

    cm = confusion_matrix(y[test_idx], y_pred)
    TN, FP, FN, TP = cm.ravel()

    acc  = (TP+TN)/(TP+TN+FP+FN)
    sens = TP/(TP+FN)
    spec = TN/(TN+FP)
    prec = TP/(TP+FP)
    f1   = 2*prec*sens/(prec+sens)
    fpr, tpr, _ = roc_curve(y[test_idx], y_pred_prob[:,1])
    auc_val = auc(fpr, tpr)

    metrics.append([acc, sens, spec, prec, f1, auc_val])
    print(f"Fold {fold+1} | Acc={acc:.4f} Sens={sens:.4f} Spec={spec:.4f} F1={f1:.4f} AUC={auc_val:.4f}")

metrics = np.array(metrics)
print(f"Mean Accuracy: {metrics[:,0].mean():.4f} ± {metrics[:,0].std():.4f}")

# SECTION 5 — FINAL MODEL (ALL DATA)
final_model = build_model(X.shape[1])
final_model.fit(X, y_cat, epochs=50, batch_size=32, verbose=1, callbacks=[early_stop])
y_pred_final = np.argmax(final_model.predict(X), axis=1)
acc_final = np.mean(y_pred_final == y)
print(f"Final model accuracy: {acc_final:.4f}")

# SECTION 6 — OUTLIER DETECTION
hidden_layer_model = tf.keras.Model(inputs=final_model.input,
                                    outputs=final_model.get_layer("hidden_layer").output)
hidden_output = hidden_layer_model.predict(X)
mu = hidden_output.mean(axis=0)
dE = np.linalg.norm(hidden_output - mu, axis=1)
threshold = dE.mean() + 3*dE.std()
outliers = dE > threshold
print(f"Outliers flagged: {outliers.sum()} / {len(dE)}")

# SECTION 7 — PCA Projection
pca = PCA(n_components=3)
score = pca.fit_transform(hidden_output)
labels = y


# SECTION 8 — EXPORT FIGURES (inline + saved)
out_dir = "/kaggle/working"
os.makedirs(out_dir, exist_ok=True)

# Confusion Matrix
plt.figure()
cm = confusion_matrix(y, y_pred_final)
plt.imshow(cm, cmap='Blues')
plt.title("Confusion Matrix (Final Model)")
plt.colorbar()
plt.savefig(os.path.join(out_dir, "confusion_matrix.png"))
plt.show()
plt.close()

# ROC Curve
y_pred_prob = final_model.predict(X)
fpr, tpr, _ = roc_curve(y, y_pred_prob[:,1])
roc_auc = auc(fpr, tpr)
plt.figure()
plt.plot(fpr, tpr, linewidth=2)
plt.plot([0,1],[0,1],'k--')
plt.xlabel("False Positive Rate")
plt.ylabel("True Positive Rate")
plt.title(f"ROC Curve (AUC = {roc_auc:.4f})")
plt.grid(True)
plt.savefig(os.path.join(out_dir, "roc_curve.png"))
plt.show()
plt.close()

# Per-Fold Metrics (Grouped Bar Plot)
metrics_names = ['Accuracy','Sensitivity','Specificity','Precision','F1','AUC']
x = np.arange(metrics.shape[0])  # folds
width = 0.15

plt.figure(figsize=(10,6))
for i in range(metrics.shape[1]):
    plt.bar(x + i*width, metrics[:,i], width, label=metrics_names[i])
plt.xlabel("Fold")
plt.ylabel("Score")
plt.title("Per-Fold Performance Metrics")
plt.ylim([0.7,1.0])
plt.legend(loc='lower center', ncol=3)
plt.grid(True)
plt.savefig(os.path.join(out_dir, "per_fold_metrics.png"))
plt.show()
plt.close()

# PCA Projection (2D)
plt.figure()
for lab in np.unique(labels):
    plt.scatter(score[labels==lab,0], score[labels==lab,1], label=le.classes_[lab])
plt.scatter(score[outliers,0], score[outliers,1], c='k', marker='s', label='Outliers')
plt.xlabel(f"PC1 ({pca.explained_variance_ratio_[0]*100:.2f}%)")
plt.ylabel(f"PC2 ({pca.explained_variance_ratio_[1]*100:.2f}%)")
plt.title("2D PCA Projection of Hidden Layer Embeddings")
plt.legend()
plt.grid(True)
plt.savefig(os.path.join(out_dir, "pca_projection_2d.png"))
plt.show()
plt.close()

# PCA Projection (3D)
fig = plt.figure()
ax = fig.add_subplot(111, projection='3d')
ax.scatter(score[:,0], score[:,1], score[:,2], c=labels, cmap='coolwarm')
ax.scatter(score[outliers,0], score[outliers,1], score[outliers,2], c='k', marker='s')
ax.set_xlabel(f"PC1 ({pca.explained_variance_ratio_[0]*100:.2f}%)")
ax.set_ylabel(f"PC2 ({pca.explained_variance_ratio_[1]*100:.2f}%)")
ax.set_zlabel(f"PC3 ({pca.explained_variance_ratio_[2]*100:.2f}%)")
ax.set_title("3D PCA Projection of Hidden Layer Embeddings")
plt.savefig(os.path.join(out_dir, "pca_projection_3d.png"))
plt.show()
plt.close()

print("✅ Figures displayed inline and exported to /kaggle/working")
